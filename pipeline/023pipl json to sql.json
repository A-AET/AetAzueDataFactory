{
	"name": "023pipl json to sql",
	"properties": {
		"activities": [
			{
				"name": "Copy json to sql",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['Country']"
								},
								"sink": {
									"name": "country",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['EnglishProductName']"
								},
								"sink": {
									"name": "englsihproductname",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['SalesAmount']"
								},
								"sink": {
									"name": "salesamount",
									"type": "Decimal"
								}
							}
						],
						"collectionReference": "",
						"mapComplexValuesToString": true
					}
				},
				"inputs": [
					{
						"referenceName": "Json3",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "AzureJSONSq",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": [],
		"lastPublishTime": "2026-02-09T13:40:31Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}